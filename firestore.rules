rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomCode} {
      // Anyone can read a room (needed to join by code)
      allow read: if true;

      // Only allow creating a room with the required fields
      allow create: if request.resource.data.keys().hasAll(['hostId', 'language', 'status', 'players', 'createdAt'])
                    && request.resource.data.status == 'waiting';

      // Only allow updating existing rooms (no deleting)
      allow update: if resource != null;

      // No deleting rooms from the client
      allow delete: if false;
    }
  }
}
